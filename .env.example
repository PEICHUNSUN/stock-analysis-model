# ============================
# API Key 設定範本
# ============================
# 請複製這個檔案，並重新命名為 .env
# 然後填入你自己的 API Key
# ⚠️ 注意：.env 這個檔案絕對不能上傳到 GitHub！

# FRED API Key（免費申請）
# 申請網址：https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_api_key_here

# Anthropic API Key（用於 AI 報告生成）
# 申請網址：https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here
